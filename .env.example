# Copy to `.env` in the repo root. `npm start` and `npm run label` load it via dotenv.

# Required for LLM labeling (`npm run label` or POST /sessions/label)
OPENAI_API_KEY=

# Optional (defaults shown)
OPENAI_MODEL=gpt-4o-mini

# HTTP server
PORT=3000
HOST=0.0.0.0

# SQLite path (default: data/activity.db under repo root)
# DB_PATH=

# CLI labeler default batch size
# LABEL_LIMIT=50
